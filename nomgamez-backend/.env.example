# NOM-GAMEZ Backend Environment Variables
# Copy this to .env and fill in with your own values
# NEVER commit .env to version control!

# Zenon Platform Wallet (REQUIRED - keep secret!)
# Generate a new seed with: node -e "const { Wallet } = require('@zenon-network/wallet'); const w = Wallet.random(); console.log('Seed:', w.seed); console.log('Address:', w.address)"
PLATFORM_SEED=your_zenon_wallet_seed_here_keep_this_secret
PLATFORM_ADDRESS=your_zenon_platform_address_here

# Bitcoin Deposit Address (REQUIRED - where user deposits go)
BTC_DEPOSIT_ADDRESS=your_btc_deposit_address_here

# Zenon Node Connection
ZNN_NODE_URL=wss://node.zenon.fun:35998
EXPLORER_API=https://zenonhub.io/api

# Bitcoin Core RPC (optional - for BTC payouts)
BTC_RPC_URL=http://127.0.0.1:8334
BTC_WALLET_RPC_URL=http://127.0.0.1:8332

# Server Config
PORT=3001
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:3000

# Admin Authentication (use a strong random token)
ADMIN_TOKEN=your_strong_random_admin_token_here
