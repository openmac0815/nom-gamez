# ─────────────────────────────────────────────
# NOM-BET BACKEND v2 — ENVIRONMENT CONFIG
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── ZENON ───────────────────────────────────

# Platform hot wallet seed (24 words)
# Receives all bets, sends all payouts
PLATFORM_SEED=word1 word2 word3 ... word24

# Platform wallet address (derived from seed above, first address)
# Shown to players as the deposit address
PLATFORM_ADDRESS=z1q...

# Zenon node WebSocket endpoint
ZNN_NODE_URL=wss://my.hc1node.com:35998

# Zenon explorer API
EXPLORER_API=https://zenonhub.io/api

# ── SERVER ──────────────────────────────────

HOST=127.0.0.1
PORT=3001
CORS_ORIGIN=http://localhost:8080
MAX_SESSIONS=100
DEPOSIT_TIMEOUT=300
LOG_LEVEL=info
LOG_REQUESTS=true

# Admin API bearer token.
# Required to use any /admin/* endpoint.
ADMIN_TOKEN=replace-with-long-random-token

# Phase 1 safety switches.
# Keep these false in production until the corresponding subsystems
# are rebuilt with server-side verification and durable settlement.
ENABLE_UNSAFE_MARKETS=false
ENABLE_UNSAFE_FREEPLAY=false

# Treasury / live-safety reference limits.
# The backend currently reads its active values from config.js and /admin/config,
# but these env entries are useful to keep your target operator values documented.
TREASURY_MIN_RESERVE_ZNN=25
TREASURY_MAX_SINGLE_PAYOUT_ZNN=50
TREASURY_MAX_PENDING_LIABILITY_ZNN=250

# ── BOT ─────────────────────────────────────

# Set to 'false' to disable the autonomous market-creation bot
BOT_ENABLED=true

# Your deployed frontend URL (linked in every social post)
PLATFORM_URL=https://nombet.io

# ── TWITTER / X ─────────────────────────────
# Get these from developer.twitter.com
# Bot posts new markets, resolutions, and big wins

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── TELEGRAM ────────────────────────────────
# Create a bot via @BotFather, add it to your channel as admin
# TELEGRAM_CHANNEL_ID can be a @channelname or numeric ID

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── WIN ANNOUNCEMENTS ────────────────────────
# Only announce wins above this ZNN threshold (prevents spam)
WIN_ANNOUNCE_MIN=2
